{
    "name": "saltbot",
    "version": "0.1.0",
    "description": "Template for Kasumi",
    "main": "index.js",
    "scripts": {
        "start": "concurrently --kill-others -n \"Bot,Web,Tunnel\" \"npm run start:bot\" \"npm run start:web\" \"npm run tunnel\"",
        "start:bot": "node --nolazy -r ts-node/register -r tsconfig-paths/register src/index.ts",
        "start:web": "npm run build:web && CONFIG_PATH=\"$PWD/src/config/config.json5\" PORT=16320 node src/webui/.output/server/index.mjs",
        "tunnel": "test -f src/config/cloudflared.yml && exec cloudflared tunnel --config src/config/cloudflared.yml run || echo 'Cloudflare tunnel not configured (src/config/cloudflared.yml missing); skipping.'",
        "build:web": "npm run build -w src/webui",
        "dev:bot": "export LOG_LEVEL=trace && npm run start:bot | pino-pretty",
        "dev:web": "npm run dev -w src/webui",
        "dev": "concurrently --kill-others -n \"Bot,Web\" \"npm run dev:bot\" \"npm run dev:web\"",
        "format": "biome format --write",
        "lint": "biome lint --write",
        "check": "biome check --write",
        "pm2": "node src/pm2/index.js"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/saltcute/saltbot.git"
    },
    "keywords": [
        "Kasumi",
        "kook",
        "bot"
    ],
    "workspaces": [
        "src/webui"
    ],
    "author": "saltcute",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/saltcute/saltbot/issues"
    },
    "homepage": "https://github.com/saltcute/saltbot#readme",
    "dependencies": {
        "@m31coding/fuzzy-search": "^1.0.2",
        "@saltcute/cache": "^1.0.5",
        "@saltcute/kasumi-essential": "^0.1.4",
        "@saltcute/kasumi-maimai": "^0.1.3",
        "@types/lodash": "^4.17.16",
        "@types/memory-cache": "^0.2.6",
        "@types/tsv": "^0.2.4",
        "concurrently": "^9.2.3",
        "discord.js": "^14.16.3",
        "fuse.js": "^7.1.0",
        "gcm-database": "^1.0.3",
        "gcm-database-local": "^1.0.12",
        "gcm-database-otogedb": "^1.0.1",
        "hono": "^4.12.27",
        "kasumi.js": "^0.6.0",
        "kuroshiro": "^1.2.0",
        "kuroshiro-analyzer-kuromoji": "^1.1.0",
        "lodash": "^4.17.21",
        "maidraw": "^0.13.5",
        "maidraw-gcm-net-adapter": "^1.0.8",
        "maidraw-kamai-tachi-adapter": "^1.0.3",
        "maidraw-lxns-adapter": "^1.0.0",
        "maidraw-maishift-adapter": "^1.0.0",
        "ts-node": "^10.9.1",
        "tsconfig-paths": "^4.1.2",
        "tsv": "^0.2.0",
        "upath": "^2.0.1"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.0",
        "typescript": "^6.0.3"
    },
    "allowScripts": {
        "canvas@3.2.3": true,
        "dtrace-provider@0.8.8": true,
        "sharp@0.32.6": true,
        "sharp@0.35.2": true,
        "sharp@0.33.5": true,
        "skia-canvas@2.0.2": true
    }
}
