{
    "name": "saltbot",
    "version": "0.1.0",
    "description": "Template for Kasumi",
    "main": "index.js",
    "scripts": {
        "start": "node --nolazy -r ts-node/register -r tsconfig-paths/register src/index.ts",
        "test": "export LOG_LEVEL=trace && npm start | bunyan -L | pino-pretty",
        "test-local": "npx install-local \"../maidraw\" && npm test",
        "format": "biome format --write",
        "lint": "biome lint --write",
        "pm2": "node src/pm2/index.js"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/saltcute/saltbot.git"
    },
    "keywords": [
        "Kasumi",
        "kook",
        "bot"
    ],
    "author": "saltcute",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/saltcute/saltbot/issues"
    },
    "homepage": "https://github.com/saltcute/saltbot#readme",
    "dependencies": {
        "@m31coding/fuzzy-search": "^1.0.2",
        "@saltcute/cache": "^1.0.5",
        "@saltcute/kasumi-essential": "^0.1.4",
        "@saltcute/kasumi-maimai": "^0.1.3",
        "@types/lodash": "^4.17.16",
        "@types/memory-cache": "^0.2.6",
        "@types/tsv": "^0.2.4",
        "discord.js": "^14.16.3",
        "fuse.js": "^7.1.0",
        "gcm-database": "^1.0.3",
        "gcm-database-local": "^1.0.12",
        "kasumi.js": "^0.6.0",
        "kuroshiro": "^1.2.0",
        "kuroshiro-analyzer-kuromoji": "^1.1.0",
        "lodash": "^4.17.21",
        "maidraw": "^0.13.2",
        "maidraw-kamai-tachi-adapter": "^1.0.2",
        "maidraw-lxns-adapter": "^1.0.0",
        "maidraw-maishift-adapter": "^1.0.0",
        "ts-node": "^10.9.1",
        "tsconfig-paths": "^4.1.2",
        "tsv": "^0.2.0",
        "upath": "^2.0.1"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.0",
        "typescript": "^6.0.3"
    },
    "allowScripts": {
        "canvas@3.2.3": true,
        "dtrace-provider@0.8.8": true,
        "sharp@0.32.6": true,
        "sharp@0.35.2": true,
        "sharp@0.33.5": true,
        "skia-canvas@2.0.2": true
    }
}
